{
  "$schema": "https://design-tokens.org/schema.json",
  "name": "claude-code-web",
  "version": "v3-design",
  "mode": "dark-only",
  "colors": {
    "bg": {
      "base":        "#19161a",
      "raised":      "#22201e",
      "surface":     "#2a2724",
      "hover":       "#332f2a",
      "accentSoft":  "#39241c"
    },
    "border": {
      "subtle":      "#2f2b27",
      "default":     "#3f3830"
    },
    "text": {
      "primary":     "#f0e8d9",
      "secondary":   "#b5a898",
      "muted":       "#7a7065",
      "inverse":     "#1a1714"
    },
    "accent": {
      "default":     "#d97757",
      "hi":          "#e28b70",
      "lo":          "#b85f44"
    },
    "status": {
      "success":     "#8aa876",
      "warning":     "#d4a95e",
      "danger":      "#c66a4f"
    }
  },
  "typography": {
    "fonts": {
      "display": "ui-serif, 'Iowan Old Style', Georgia, serif",
      "body":    "'Inter', -apple-system, system-ui, 'Segoe UI', Roboto, sans-serif",
      "mono":    "'JetBrains Mono', 'SF Mono', ui-monospace, Menlo, monospace"
    },
    "weights": { "regular": 400, "medium": 500, "semibold": 600 },
    "scale": {
      "xs":   { "size": "11px", "line": "16px" },
      "sm":   { "size": "13px", "line": "20px" },
      "base": { "size": "15px", "line": "24px" },
      "lg":   { "size": "17px", "line": "26px" },
      "xl":   { "size": "22px", "line": "30px" }
    }
  },
  "motion": {
    "duration": {
      "hover":  "120ms",
      "enter":  "180ms",
      "modal":  "220ms",
      "exit":   "140ms",
      "mode":   "240ms"
    },
    "easing": {
      "out":    "cubic-bezier(.22, 1, .36, 1)",
      "spring": "cubic-bezier(.34, 1.56, .64, 1)",
      "soft":   "cubic-bezier(.4, 0, .2, 1)"
    }
  },
  "radii": {
    "sm": "6px",
    "md": "10px",
    "lg": "14px",
    "xl": "20px",
    "full": "9999px"
  },
  "shadows": {
    "pop":   "0 1px 0 rgba(255,230,200,.02) inset, 0 6px 20px -8px rgba(0,0,0,.6)",
    "modal": "0 24px 60px -16px rgba(0,0,0,.7), 0 0 0 1px rgba(63,56,48,1)"
  },
  "layout": {
    "sidebarWidth":   "288px",
    "topbarHeight":   "44px",
    "contentMaxW":    "720px",
    "inputFloat":     "24px",
    "modalMaxW":      "560px",
    "paletteW":       "640px",
    "paletteH":       "420px"
  },
  "accessibility": {
    "focusRing": {
      "color":  "#d97757",
      "width":  "2px",
      "offset": "2px"
    },
    "minHit":   "36px"
  }
}
