{
  "name": "claudecode-web",
  "version": "0.1.0",
  "description": "Self-hosted skinable web workspace for local or remote Claude Code",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fafawlf/claude-code-web.git"
  },
  "bugs": {
    "url": "https://github.com/fafawlf/claude-code-web/issues"
  },
  "homepage": "https://github.com/fafawlf/claude-code-web#readme",
  "keywords": [
    "claude-code",
    "claude",
    "web-ui",
    "ssh",
    "tui",
    "agent",
    "self-hosted"
  ],
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "build": "npm run build -w server && npm run build -w web",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "start": "node server/dist/index.js",
    "test": "tsx --test web/src/__tests__/*.test.ts server/src/__tests__/*.test.ts"
  },
  "bin": {
    "claudecode-web": "./server/dist/bin/claudecode-web.js"
  }
}
